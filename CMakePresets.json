{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21
  },

  "configurePresets": [
    {
      "name": "debug",
      "displayName": "Debug",
      "generator": "Unix Makefiles",
      "binaryDir": "build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_WORKQ_TESTS": "ON",
        "CMAKE_INSTALL_PREFIX": "/usr/local"
      }
    },

    {
      "name": "release",
      "displayName": "Release",
      "generator": "Unix Makefiles",
      "binaryDir": "build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_WORKQ_TESTS": "ON",
        "CMAKE_INSTALL_PREFIX": "/usr/local"
      }
    },

    {
      "name": "valgrind-debug",
      "displayName": "Valgrind Debug",
      "description": "Debug build optimized for Valgrind/Helgrind (no inline, full symbols, no optimizations)",
      "generator": "Unix Makefiles",
      "binaryDir": "build/valgrind",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "ValgrindDebug",
        "BUILD_WORKQ_TESTS": "ON",
        "CMAKE_INSTALL_PREFIX": "/usr/local",
        "CMAKE_CXX_FLAGS_VALGRINDDEBUG": "-O0 -g3 -fno-omit-frame-pointer -fno-inline -fno-optimize-sibling-calls",
        "CMAKE_C_FLAGS_VALGRINDDEBUG": "-O0 -g3 -fno-omit-frame-pointer -fno-inline -fno-optimize-sibling-calls"
      }
    }
  ],

  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "valgrind-debug",
      "configurePreset": "valgrind-debug"
    }
  ],

  "testPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "valgrind-debug",
      "configurePreset": "valgrind-debug"
    }
  ]
}
